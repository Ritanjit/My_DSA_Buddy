# GitHub Personal Access Token (for syncing solutions to your repo)
# Generate at: https://github.com/settings/tokens
# Required scopes: repo (Full control of private repositories)
GITHUB_PAT=

# GitHub repository (owner/repo format)
GITHUB_REPO=

# GitHub branch (default: main)
GITHUB_BRANCH=main

# GitHub username (for contribution graph on Dashboard)
GITHUB_USERNAME=

# LeetCode username (for contribution graph on Dashboard)
LEETCODE_USERNAME=
